---
import { getCollection } from 'astro:content';
import BlogCard from '../components/BlogCard.astro';
import SchemaOrg from '../components/SchemaOrg.astro';
import { SITE_DESCRIPTION, SITE_TITLE, CATEGORY_LABELS, type Category } from '../consts';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('blog'))
	.filter((post) => !post.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 10);
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<SchemaOrg type="website" description={SITE_DESCRIPTION} />

	<!-- Hero Section -->
	<section class="bg-gradient-to-b from-blue-50 to-white py-16">
		<div class="max-w-4xl mx-auto px-4 text-center">
			<h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
				Smart Money Moves for<br />Southeast Asia
			</h1>
			<p class="text-lg text-gray-600 max-w-2xl mx-auto">
				Your guide to personal finance, fintech, and building wealth in Indonesia. Practical tips,
				honest reviews, and actionable advice.
			</p>
		</div>
	</section>

	<!-- Latest Posts -->
	<section class="max-w-5xl mx-auto px-4 py-12">
		<h2 class="text-2xl font-bold text-gray-900 mb-8">Latest Articles</h2>
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
			{posts.map((post) => (
				<BlogCard
					title={post.data.title}
					description={post.data.description}
					pubDate={post.data.pubDate}
					category={post.data.category}
					slug={post.id}
					heroImage={post.data.heroImage}
				/>
			))}
		</div>
		<div class="text-center mt-10">
			<a
				href="/blog"
				class="inline-block px-6 py-3 bg-blue-600 text-white rounded-lg font-medium no-underline hover:bg-blue-700 transition-colors"
			>
				View All Articles
			</a>
		</div>
	</section>

	<!-- Categories Section -->
	<section class="bg-gray-50 py-12">
		<div class="max-w-5xl mx-auto px-4">
			<h2 class="text-2xl font-bold text-gray-900 mb-8">Browse by Category</h2>
			<div class="grid grid-cols-2 md:grid-cols-4 gap-4">
				{Object.entries(CATEGORY_LABELS).map(([slug, label]) => (
					<a
						href={`/category/${slug}`}
						class="block p-4 bg-white rounded-lg border border-gray-200 text-center no-underline hover:border-blue-300 hover:shadow-md transition-all"
					>
						<span class="text-gray-900 font-medium">{label}</span>
					</a>
				))}
			</div>
		</div>
	</section>
</BaseLayout>
