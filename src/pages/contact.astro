---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Get in touch with Evan Today. We'd love to hear from you.">
	<div class="max-w-3xl mx-auto px-4 py-12">
		<h1 class="text-3xl font-bold text-gray-900 mb-6">Contact Us</h1>
		<div class="prose">
			<p>
				Have a question, suggestion, or business inquiry? We'd love to hear from you.
			</p>
			<h2>Get In Touch</h2>
			<p>
				The best way to reach us is via email at
				<a href="mailto:hello@evantoday.id">hello@evantoday.id</a>.
			</p>
			<h2>Business Inquiries</h2>
			<p>
				For advertising, sponsorships, or partnership opportunities, please email us with
				the subject line "Business Inquiry" and we'll get back to you within 48 hours.
			</p>
		</div>
	</div>
</BaseLayout>
