---
interface Props {
	body: string;
}

interface FaqItem {
	question: string;
	answer: string;
}

const { body } = Astro.props;

function parseFaqItems(content: string): FaqItem[] {
	const items: FaqItem[] = [];
	if (!content) return items;

	// Find the FAQ section starting with "## Frequently Asked Questions"
	const faqMatch = content.match(/## (?:Frequently Asked Questions|Pertanyaan yang Sering Diajukan|FAQ[:\s])\s*\n([\s\S]*?)(?=\n## [^#]|$)/i);
	if (!faqMatch) return items;

	const faqSection = faqMatch[1];

	// Split by ### headings to get individual Q&A pairs
	const parts = faqSection.split(/### /);

	for (const part of parts) {
		const trimmed = part.trim();
		if (!trimmed) continue;

		// First line is the question, rest is the answer
		const lines = trimmed.split('\n');
		const question = lines[0].replace(/\*\*/g, '').trim();
		if (!question) continue;

		// Collect answer lines (skip empty lines right after question)
		const answerLines = lines.slice(1)
			.map(line => line.trim())
			.filter(line => line.length > 0)
			// Strip markdown formatting for the schema text
			.map(line => line.replace(/\[([^\]]+)\]\([^)]+\)/g, '$1').replace(/[*_`#]/g, '').trim())
			.filter(line => line.length > 0);

		const answer = answerLines.join(' ');
		if (answer) {
			items.push({ question, answer });
		}
	}

	return items;
}

const faqItems = parseFaqItems(body);

const schema = faqItems.length > 0 ? {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	"mainEntity": faqItems.map(item => ({
		"@type": "Question",
		"name": item.question,
		"acceptedAnswer": {
			"@type": "Answer",
			"text": item.answer,
		},
	})),
} : null;
---

{schema && (
	<script type="application/ld+json" set:html={JSON.stringify(schema)} />
)}
