---
import { Image } from 'astro:assets';
import FormattedDate from './FormattedDate.astro';
import { CATEGORY_LABELS, type Category } from '../consts';
import type { ImageMetadata } from 'astro';

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	category: Category;
	slug: string;
	heroImage?: ImageMetadata;
	readingTime?: number;
}

const { title, description, pubDate, category, slug, heroImage, readingTime } = Astro.props;

const categoryColors: Record<string, string> = {
	'personal-finance': 'from-blue-500 to-blue-700',
	'fintech': 'from-violet-500 to-violet-700',
	'cryptocurrency': 'from-orange-500 to-amber-600',
	'insurance': 'from-emerald-500 to-emerald-700',
	'investing': 'from-teal-500 to-teal-700',
	'digital-banking': 'from-cyan-500 to-cyan-700',
	'financial-tips': 'from-amber-500 to-amber-700',
};
const gradientClass = categoryColors[category] || 'from-gray-500 to-gray-700';
---

<article class="group bg-white rounded-xl border border-gray-200 overflow-hidden hover:shadow-xl hover:border-gray-300 transition-all duration-300">
	<a href={`/blog/${slug}/`} class="block no-underline">
		{heroImage ? (
			<Image
				src={heroImage}
				alt={title}
				width={720}
				height={360}
				class="w-full h-48 object-cover"
			/>
		) : (
			<div class={`w-full h-48 bg-gradient-to-br ${gradientClass} flex items-end p-5`}>
				<span class="text-white/90 text-sm font-semibold bg-black/20 backdrop-blur-sm px-3 py-1 rounded-lg">
					{CATEGORY_LABELS[category]}
				</span>
			</div>
		)}
		<div class="p-5 space-y-3">
			<div class="flex items-center gap-2 text-xs text-gray-400">
				<span class="text-blue-600 font-semibold">{CATEGORY_LABELS[category]}</span>
				<span>&#183;</span>
				<FormattedDate date={pubDate} />
				{readingTime && (
					<>
						<span>&#183;</span>
						<span>{readingTime} min read</span>
					</>
				)}
			</div>
			<h3 class="text-base font-bold text-gray-900 group-hover:text-blue-600 transition-colors leading-snug line-clamp-2">
				{title}
			</h3>
			<p class="text-gray-500 text-sm leading-relaxed line-clamp-2">{description}</p>
		</div>
	</a>
</article>
