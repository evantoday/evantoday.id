---
import FormattedDate from './FormattedDate.astro';
import { CATEGORY_LABELS, type Category } from '../consts';

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	category: Category;
	slug: string;
	heroImage?: any;
	readingTime?: number;
}

const { title, description, pubDate, category, slug, readingTime } = Astro.props;
---

<article class="group">
	<a href={`/blog/${slug}/`} class="block no-underline">
		<div class="space-y-2">
			<div class="flex items-center gap-2 text-xs text-gray-400">
				<span class="font-medium text-gray-500">{CATEGORY_LABELS[category]}</span>
				<span>/</span>
				<FormattedDate date={pubDate} />
				{readingTime && (
					<>
						<span>/</span>
						<span>{readingTime} min</span>
					</>
				)}
			</div>
			<h3 class="text-base font-semibold text-gray-900 group-hover:text-blue-600 transition-colors leading-snug">
				{title}
			</h3>
			<p class="text-sm text-gray-500 leading-relaxed line-clamp-2">{description}</p>
		</div>
	</a>
</article>
