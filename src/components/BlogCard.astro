---
import { Image } from 'astro:assets';
import FormattedDate from './FormattedDate.astro';
import { CATEGORY_LABELS, type Category } from '../consts';
import type { ImageMetadata } from 'astro';

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	category: Category;
	slug: string;
	heroImage?: ImageMetadata;
}

const { title, description, pubDate, category, slug, heroImage } = Astro.props;
---

<article class="group">
	<a href={`/blog/${slug}/`} class="block no-underline">
		{heroImage && (
			<Image
				src={heroImage}
				alt={title}
				width={720}
				height={360}
				class="w-full h-48 object-cover rounded-lg mb-4 group-hover:shadow-lg transition-shadow"
			/>
		)}
		<div class="space-y-2">
			<div class="flex items-center gap-3 text-sm">
				<span class="text-blue-600 font-medium">{CATEGORY_LABELS[category]}</span>
				<span class="text-gray-400">|</span>
				<span class="text-gray-500"><FormattedDate date={pubDate} /></span>
			</div>
			<h3 class="text-lg font-bold text-gray-900 group-hover:text-blue-600 transition-colors leading-snug">
				{title}
			</h3>
			<p class="text-gray-600 text-sm line-clamp-2">{description}</p>
		</div>
	</a>
</article>
