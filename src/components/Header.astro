---
import { SITE_TITLE } from '../consts';

const pathname = Astro.url.pathname;
---

<header class="bg-white border-b border-gray-200 sticky top-0 z-50">
	<nav class="max-w-5xl mx-auto px-4 py-3 flex items-center justify-between">
		<a href="/" class="text-xl font-bold text-gray-900 hover:text-blue-600 no-underline">
			{SITE_TITLE}
		</a>

		<!-- Mobile menu button -->
		<button
			id="menu-toggle"
			class="md:hidden p-2 text-gray-600 hover:text-gray-900"
			aria-label="Toggle menu"
		>
			<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				<path id="menu-open-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
				<path id="menu-close-icon" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
			</svg>
		</button>

		<!-- Desktop nav -->
		<div class="hidden md:flex items-center gap-6">
			<a
				href="/"
				class:list={[
					'text-sm font-medium no-underline',
					pathname === '/' ? 'text-blue-600' : 'text-gray-600 hover:text-gray-900',
				]}
			>
				Home
			</a>
			<a
				href="/blog"
				class:list={[
					'text-sm font-medium no-underline',
					pathname.startsWith('/blog') ? 'text-blue-600' : 'text-gray-600 hover:text-gray-900',
				]}
			>
				Blog
			</a>
			<a
				href="/about"
				class:list={[
					'text-sm font-medium no-underline',
					pathname === '/about' ? 'text-blue-600' : 'text-gray-600 hover:text-gray-900',
				]}
			>
				About
			</a>
			<a
				href="/contact"
				class:list={[
					'text-sm font-medium no-underline',
					pathname === '/contact' ? 'text-blue-600' : 'text-gray-600 hover:text-gray-900',
				]}
			>
				Contact
			</a>
		</div>
	</nav>

	<!-- Mobile nav -->
	<div id="mobile-menu" class="hidden md:hidden border-t border-gray-200 bg-white">
		<div class="px-4 py-3 space-y-3">
			<a
				href="/"
				class:list={[
					'block text-sm font-medium no-underline',
					pathname === '/' ? 'text-blue-600' : 'text-gray-600',
				]}
			>
				Home
			</a>
			<a
				href="/blog"
				class:list={[
					'block text-sm font-medium no-underline',
					pathname.startsWith('/blog') ? 'text-blue-600' : 'text-gray-600',
				]}
			>
				Blog
			</a>
			<a
				href="/about"
				class:list={[
					'block text-sm font-medium no-underline',
					pathname === '/about' ? 'text-blue-600' : 'text-gray-600',
				]}
			>
				About
			</a>
			<a
				href="/contact"
				class:list={[
					'block text-sm font-medium no-underline',
					pathname === '/contact' ? 'text-blue-600' : 'text-gray-600',
				]}
			>
				Contact
			</a>
		</div>
	</div>
</header>

<script is:inline>
	document.getElementById('menu-toggle').addEventListener('click', () => {
		const menu = document.getElementById('mobile-menu');
		const openIcon = document.getElementById('menu-open-icon');
		const closeIcon = document.getElementById('menu-close-icon');
		menu.classList.toggle('hidden');
		openIcon.classList.toggle('hidden');
		closeIcon.classList.toggle('hidden');
	});
</script>
