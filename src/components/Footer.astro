		<div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-sm">
			<div class="col-span-2 md:col-span-1">
				<span class="font-bold text-gray-900">Evan Today</span>
				<p class="text-gray-400 mt-2 leading-relaxed">
					Tips keuangan praktis yang benar-benar works.
				</p>
			</div>
			<div>
				<h3 class="font-medium text-gray-900 mb-3">Topik</h3>
				<ul class="space-y-2 text-gray-500">
					<li><a href="/category/personal-finance" class="hover:text-gray-900 no-underline">Keuangan Pribadi</a></li>
					<li><a href="/category/fintech" class="hover:text-gray-900 no-underline">Fintech</a></li>
					<li><a href="/category/investing" class="hover:text-gray-900 no-underline">Investasi</a></li>
					<li><a href="/category/cryptocurrency" class="hover:text-gray-900 no-underline">Crypto</a></li>
