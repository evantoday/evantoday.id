---
const year = new Date().getFullYear();
---

<footer class="bg-gray-900 text-gray-300 mt-20">
	<div class="max-w-6xl mx-auto px-4 sm:px-6 py-16">
		<div class="grid grid-cols-1 md:grid-cols-4 gap-10">
			<!-- Brand -->
			<div class="md:col-span-1">
				<div class="flex items-center gap-2.5 mb-4">
					<div class="w-9 h-9 bg-gradient-to-br from-slate-600 to-slate-700 rounded-lg flex items-center justify-center">
						<span class="text-white text-sm font-bold tracking-tight">ET</span>
					</div>
					<span class="text-lg font-bold text-white">Evan Today</span>
				</div>
				<p class="text-sm text-gray-400 leading-relaxed">
					Your trusted guide to personal finance, fintech, and building wealth in Indonesia and Southeast Asia.
				</p>
			</div>

			<!-- Categories -->
			<div>
				<h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Categories</h3>
				<ul class="space-y-2.5 text-sm">
					<li><a href="/category/personal-finance" class="text-gray-400 hover:text-white no-underline transition-colors">Personal Finance</a></li>
					<li><a href="/category/fintech" class="text-gray-400 hover:text-white no-underline transition-colors">Fintech</a></li>
					<li><a href="/category/investing" class="text-gray-400 hover:text-white no-underline transition-colors">Investing</a></li>
					<li><a href="/category/cryptocurrency" class="text-gray-400 hover:text-white no-underline transition-colors">Cryptocurrency</a></li>
					<li><a href="/category/insurance" class="text-gray-400 hover:text-white no-underline transition-colors">Insurance</a></li>
					<li><a href="/category/digital-banking" class="text-gray-400 hover:text-white no-underline transition-colors">Digital Banking</a></li>
				</ul>
			</div>

			<!-- Company -->
			<div>
				<h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Company</h3>
				<ul class="space-y-2.5 text-sm">
					<li><a href="/about" class="text-gray-400 hover:text-white no-underline transition-colors">About Us</a></li>
					<li><a href="/contact" class="text-gray-400 hover:text-white no-underline transition-colors">Contact</a></li>
					<li><a href="/blog" class="text-gray-400 hover:text-white no-underline transition-colors">All Articles</a></li>
				</ul>
			</div>

			<!-- Legal -->
			<div>
				<h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Legal</h3>
				<ul class="space-y-2.5 text-sm">
					<li><a href="/privacy-policy" class="text-gray-400 hover:text-white no-underline transition-colors">Privacy Policy</a></li>
					<li><a href="/disclaimer" class="text-gray-400 hover:text-white no-underline transition-colors">Disclaimer</a></li>
				</ul>
			</div>
		</div>

		<div class="border-t border-gray-800 mt-12 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
			<p class="text-sm text-gray-500">&copy; {year} Evan Today. All rights reserved.</p>
			<p class="text-sm text-gray-500">Made with care in Indonesia</p>
		</div>
	</div>
</footer>
