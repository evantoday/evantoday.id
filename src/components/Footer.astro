---
const year = new Date().getFullYear();
---

<footer class="bg-gray-50 border-t border-gray-200 mt-16">
	<div class="max-w-5xl mx-auto px-4 py-12">
		<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
			<div>
				<h3 class="font-bold text-gray-900 mb-3">Evan Today</h3>
				<p class="text-sm text-gray-600">
					Personal finance, fintech insights, and money management tips for Indonesia and Southeast Asia.
				</p>
			</div>
			<div>
				<h3 class="font-bold text-gray-900 mb-3">Categories</h3>
				<ul class="space-y-2 text-sm">
					<li><a href="/category/personal-finance" class="text-gray-600 hover:text-blue-600 no-underline">Personal Finance</a></li>
					<li><a href="/category/fintech" class="text-gray-600 hover:text-blue-600 no-underline">Fintech</a></li>
					<li><a href="/category/investing" class="text-gray-600 hover:text-blue-600 no-underline">Investing</a></li>
					<li><a href="/category/cryptocurrency" class="text-gray-600 hover:text-blue-600 no-underline">Cryptocurrency</a></li>
				</ul>
			</div>
			<div>
				<h3 class="font-bold text-gray-900 mb-3">Legal</h3>
				<ul class="space-y-2 text-sm">
					<li><a href="/privacy-policy" class="text-gray-600 hover:text-blue-600 no-underline">Privacy Policy</a></li>
					<li><a href="/disclaimer" class="text-gray-600 hover:text-blue-600 no-underline">Disclaimer</a></li>
					<li><a href="/contact" class="text-gray-600 hover:text-blue-600 no-underline">Contact</a></li>
				</ul>
			</div>
		</div>
		<div class="border-t border-gray-200 mt-8 pt-8 text-center text-sm text-gray-500">
			&copy; {year} Evan Today. All rights reserved.
		</div>
	</div>
</footer>
